# Rename this file to .env and fill in your values

# Required — OpenWeatherMap API key
OPENWEATHERMAP_API_KEY=YOUR_API_KEY_HERE

# Required — Google Earth Engine service account
GOOGLE_APPLICATION_CREDENTIALS=credentials/gee-service-account.json
GEE_PROJECT_ID=YOUR_GEE_PROJECT_ID

# Optional — frontend password protection
# APP_PASSWORD=your_password

# Optional — allowlist origins for backend CORS (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Optional — enable legacy prediction routes (0/1)
# LEGACY_PREDICTION=0

# Optional — logging
# LOG_LEVEL=INFO

# Optional — backend URL override (for frontend container)
# BACKEND_URL=http://backend:8000

# Optional — max-accuracy job persistence directory
# MAX_ACCURACY_JOBS_DIR=data/max_accuracy_jobs

# Optional — Redis connection settings (used by cache service and prod stack)
# REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=your_redis_password

# Optional — scouting import upload size limit (bytes)
# MAX_SCOUTING_IMPORT_BYTES=5242880
