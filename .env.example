
# Rename this file to .env and fill in your API keys
OPENWEATHERMAP_API_KEY="YOUR_API_KEY_HERE"

# Optional: enable dense LiDAR pre-scan (heavy) before GEE refinement
# LIDAR_DENSE_SCAN_ENABLED="true"
# LIDAR_DENSE_SCAN_POINTS="200000"
# LIDAR_DENSE_SCAN_RADIUS_M="800"
# LIDAR_DENSE_SCAN_TOP_K="20"
# LIDAR_DENSE_SCAN_TERRAIN_THRESHOLD="0"
# LIDAR_DENSE_SCAN_CHUNK_SIZE="2000"
# LIDAR_DENSE_SCAN_MIN_SEPARATION_M="75"
